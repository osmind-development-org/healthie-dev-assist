# Healthie API key (required)
HEALTHIE_API_KEY=your_api_key_here

# Environment: staging only (production is not supported — see README)
# HEALTHIE_ENV=staging

# Optional: path to environments.json for multi-env support
# ENVIRONMENTS_FILE=./environments.json

# Optional: GraphQL API version (`Healthie-GraphQL-API-Version` header). Overrides per-env graphqlApiVersion in environments.json when set.
# HEALTHIE_GRAPHQL_API_VERSION=2025-11-30
